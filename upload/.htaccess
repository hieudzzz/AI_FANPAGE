# Chặn thực thi tất cả file script trong thư mục này
<FilesMatch "\.(php|php3|php4|php5|php7|php8|phtml|phar|pl|py|jsp|asp|aspx|sh|cgi|shtml|cfm)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Không cho phép directory listing
Options -Indexes

# Chỉ cho phép serve file ảnh và video
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_FILENAME} \.(php|php\d|phtml|phar|pl|py|cgi|sh)$ [NC]
    RewriteRule ^ - [F,L]
</IfModule>
